{
  "expo": {
    "name": "Traffic Analyzer iOS",
    "slug": "traffic-analyzer-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "traffic-analyzer-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#070d1a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trafficanalyzer.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to automatically detect and count vehicles, cyclists, and pedestrians in real time"
      }
    },
    "android": {
      "package": "com.trafficanalyzer.mobile",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
